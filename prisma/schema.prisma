// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Site {
  id           Int       @id @default(autoincrement())
  trackingCode String    @unique @map("tracking_code")
  name         String?
  createdAt    DateTime  @default(now()) @map("created_at")
  sessions     Session[]
  events       Event[]

  @@map("sites")
}

model Session {
  siteId       Int
  sessionId    String
  site         Site     @relation(fields: [siteId], references: [id])
  startTime    DateTime @default(now()) @map("start_time")
  lastActivity DateTime @updatedAt @map("last_activity")
  pageViews    Int      @default(1) @map("page_views")
  country      String?
  userAgent    String?
  events       Event[]

  @@id([siteId, sessionId])
  @@map("sessions")
}

model Event {
  id        Int     @id @default(autoincrement())
  siteId    Int
  sessionId String
  session   Session @relation(fields: [siteId, sessionId], references: [siteId, sessionId])

  url          String
  referrer     String?
  screenWidth  Int     @map("screen_width")
  screenHeight Int     @map("screen_height")
  country      String?
  maxScroll    Int     @map("max_scroll")
  userAgent    String? @map("user_agent")
  language     String? @map("language")
  utmSource    String? @map("utm_source")
  utmMedium    String? @map("utm_medium")
  utmTerm      String? @map("utm_term")
  utmContent   String? @map("utm_content")
  utmCampaign  String? @map("utm_campaign")

  createdAt DateTime @default(now()) @map("created_at")
  site      Site     @relation(fields: [siteId], references: [id])

  @@index([siteId])
  @@map("events")
}
