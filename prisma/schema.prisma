// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Site {
  id           Int       @id @default(autoincrement())
  trackingCode String    @unique @map("tracking_code")
  name         String?
  createdAt    DateTime  @default(now()) @map("created_at")
  sessions     Session[]
  events       Event[]

  @@map("sites")
}

model Session {
  siteId       Int
  sessionId    String
  site         Site     @relation(fields: [siteId], references: [id])
  startTime    DateTime @default(now()) @map("start_time")
  lastActivity DateTime @updatedAt @map("last_activity")
  pageViews    Int      @default(1) @map("page_views")
  country      String?
  userAgent    String?
  events       Event[]

  @@id([siteId, sessionId])
  @@map("sessions")
}

model Event {
  id               Int      @id @default(autoincrement())
  side             Site     @relation(fields: [siteId], references: [id])
  siteId           Int      @map("site_id")
  url              String
  referrer         String?
  screenWidth      Int      @map("screen_width")
  screenHeight     Int      @map("screen_height")
  country          String?
  sessionId        String   @map("session_id")
  maxScroll        Int      @map("max_scroll")
  createdAt        DateTime @default(now()) @map("created_at")
  session          Session? @relation(fields: [sessionSiteId, sessionSessionId], references: [siteId, sessionId])
  sessionSiteId    Int?
  sessionSessionId String?

  @@map("events")
}
